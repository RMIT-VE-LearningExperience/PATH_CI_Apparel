# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
GA_PROPERTY_ID="your-ga4-property-id"

# Server-side Firebase Admin credentials
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"

# Optional fallback to explicit credentials instead of GOOGLE_APPLICATION_CREDENTIALS
# FIREBASE_CLIENT_EMAIL="..."

# Per-app isolation within a shared Firebase project/bucket.
# Convention: use this app's folder-name slug (e.g. "path-ci-apparel") for all three,
# so Firestore data, Storage uploads, and Cloud Functions don't collide with other PATH apps.
FIREBASE_DATABASE_ID="your-app-slug"
FIREBASE_ADMIN_DATABASE_ID="your-app-slug"
STORAGE_PATH_PREFIX="your-app-slug"
